# Anthropic Claude API
# Koppel hier je Claude API key zodra je de AI live wilt zetten
# Zonder key gebruikt de app automatisch de mock responses
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model — gebruik claude-sonnet-4-6 als standaard
ANTHROPIC_MODEL=claude-sonnet-4-6

# App URL (voor productie)
NEXT_PUBLIC_APP_URL=https://jouw-app.railway.app

# Mock mode — zet op "true" om altijd mock responses te gebruiken
NEXT_PUBLIC_USE_MOCK=false
